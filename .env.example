# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Application ID (from Discord Developer Portal > General Information)
CLIENT_ID=

# Guild ID for instant slash command registration (optional — omit for global)
GUILD_ID=

# Custom emojis — uploads Warframe-themed emojis to your server (optional)
# Set to true to auto-upload and use custom emojis, false for Unicode fallbacks
USE_CUSTOM_EMOJIS=false

# How often to refresh data (in seconds)
REFRESH_INTERVAL_SECONDS=60

# Channel IDs — right-click channel > Copy Channel ID (enable Developer Mode in Discord settings)
# Leave blank to disable a tracker

FISSURE_CHANNEL_ID=
BARO_CHANNEL_ID=
SORTIE_CHANNEL_ID=
ARCHON_CHANNEL_ID=
INVASIONS_CHANNEL_ID=
STORMS_CHANNEL_ID=
CYCLES_CHANNEL_ID=
DARVO_CHANNEL_ID=
NIGHTWAVE_CHANNEL_ID=
CIRCUIT_CHANNEL_ID=
ALERTS_CHANNEL_ID=
BOOSTERS_CHANNEL_ID=
EVENTS_CHANNEL_ID=
VARZIA_CHANNEL_ID=
ARCHIMEDEA_CHANNEL_ID=
FOMORIAN_CHANNEL_ID=
STEELPATH_CHANNEL_ID=
